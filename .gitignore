# ─── Run outputs (generated content) ──────────────────────
runs/
skill/**/runs/

# ─── Brand profiles + presets (private — real assets) ─────
# To share a public brand kit, override per-folder:
#   !brands/<name>/profile.md
brands/
presets/

# ─── Media binaries (defense-in-depth) ────────────────────
# If the agent ever slips and writes outside a run dir, this catches it.
# To commit a doc image, add an exception:
#   !docs/**/*.png
*.mp4
*.mov
*.mkv
*.webm
*.avi
*.m4a
*.mp3
*.wav
*.png
*.jpg
*.jpeg

# ─── Downloaded research artefacts ────────────────────────
downloads/

# ─── Browser automation leftovers (v1/v2 architecture) ────
.playwright-mcp/

# ─── Local agent install/runtime folders ──────────────────
# Agent-specific folders should be symlink targets only. The canonical
# source lives in skill/higgsfield-autopilot/ and commands/claude/.
.claude/
.codex/
.gemini/
.agents/

# ─── OS / editor cruft ────────────────────────────────────
.DS_Store
._*
.vscode/
.idea/
*.swp
*~

# ─── Secrets ──────────────────────────────────────────────
.env
.env.local
*.pem
*.key
secrets/
credentials.json

# ─── Logs ─────────────────────────────────────────────────
*.log
